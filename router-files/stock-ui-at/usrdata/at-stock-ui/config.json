{
  "_note": "Stock UI AT terminal config. This variant shares the same lock path as the standalone AT tool so both UIs cannot access the modem AT path at the same time.",
  "max_command_len": 128,
  "max_response_bytes": 16384,
  "backend_mode": "smd7_direct",
  "backend_modes": {
    "smd7_direct": {
      "device_path": "/dev/smd7"
    },
    "at_mdm0_direct": {
      "device_path": "/dev/at_mdm0"
    },
    "smd11_direct": {
      "device_path": "/dev/smd11"
    },
    "at_usb2_direct": {
      "device_path": "/dev/at_usb2"
    }
  },
  "lock_path": "/tmp/at-http.lock",
  "read_timeout_ms": 1500,
  "hard_timeout_ms": 5000,
  "poll_interval_ms": 50
}
